# Copy this file to .env.local-tunnel and fill real credentials locally.
# Do not commit .env.local-tunnel.

COMPOSE_PROJECT_NAME=yudao-local-tunnel

# Bind only to localhost by default.
SERVER_BIND_ADDR=127.0.0.1
SERVER_PUBLISHED_PORT=48080
FRONTEND_BIND_ADDR=127.0.0.1
FRONTEND_PUBLISHED_PORT=2828

SERVER_IMAGE=yudao-server:local-tunnel
FRONTEND_IMAGE=yudao-admin:local-tunnel
SSH_TUNNEL_IMAGE=maven:3.9.9-eclipse-temurin-17
SSH_TUNNEL_HOST=120.236.17.146
SSH_TUNNEL_PORT=2222
SSH_TUNNEL_USER=Administrator
SSH_TUNNEL_KEY_FILE=/Volumes/LVLIAN_1T/code/ssh-tunnel-config/客户端/mac/keys/ssh_tunnel_120_236_17_146
SSH_TUNNEL_KNOWN_HOSTS_FILE=/Volumes/LVLIAN_1T/code/ssh-tunnel-config/客户端/mac/known_hosts

SPRING_PROFILES_ACTIVE=local
JAVA_OPTS=-Xms512m -Xmx512m -Djava.security.egd=file:/dev/./urandom -Djava.net.preferIPv4Stack=true

# Local development must use /Volumes/LVLIAN_1T/code/ssh-tunnel-config.
# docker-compose.local-tunnel.yml starts an internal ssh-tunnel sidecar.
# The backend container connects to that sidecar; no MySQL/Redis ports are published to the Mac or LAN.
MASTER_DATASOURCE_URL=jdbc:mysql://ssh-tunnel:3306/ruoyi-vue-pro?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&nullCatalogMeansCurrent=true&rewriteBatchedStatements=true
MASTER_DATASOURCE_USERNAME=root
MASTER_DATASOURCE_PASSWORD=CHANGE_ME
SLAVE_DATASOURCE_URL=jdbc:mysql://ssh-tunnel:3306/ruoyi-vue-pro?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&nullCatalogMeansCurrent=true&rewriteBatchedStatements=true
SLAVE_DATASOURCE_USERNAME=root
SLAVE_DATASOURCE_PASSWORD=CHANGE_ME

REDIS_HOST=ssh-tunnel
REDIS_PORT=6379
REDIS_DATABASE=0
# Leave empty when Redis has no password.
# If Redis has a password, set for example:
# REDIS_PASSWORD_ARG=--spring.data.redis.password=your_password --spring.redis.password=your_password
REDIS_PASSWORD_ARG=

# Build the frontend as same-origin. Nginx proxies /admin-api to the backend.
FRONTEND_VITE_BASE_URL=
FRONTEND_VITE_API_URL=/admin-api
FRONTEND_VITE_BASE_PATH=/
FRONTEND_VITE_OUT_DIR=dist-docker
FRONTEND_DEFAULT_LOGIN_TENANT=南山
FRONTEND_NODE_OPTIONS=--max-old-space-size=1536
FRONTEND_VITE_BUILD_EXTRA_ARGS=--minify esbuild
